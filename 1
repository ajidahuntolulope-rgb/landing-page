                    </div>
                `;
                e.target.setAttribute('r', '6');
                e.target.style.fill = '#121212';
            });
        });

        // 2. Tab Context Switcher Logic
        function switchTab(tab) {
            currentTab = tab;
            const btnSafety = document.getElementById('tab-safety');
            const btnWriting = document.getElementById('tab-writing');
            const contentSafety = document.getElementById('content-safety');
            const contentWriting = document.getElementById('content-writing');

            if (tab === 'safety') {
                btnSafety.className = "px-6 py-2.5 text-xs tracking-widest uppercase bg-white text-luxuryBlack font-medium transition-all duration-300";
                btnWriting.className = "px-6 py-2.5 text-xs tracking-widest uppercase text-mutedGray hover:text-white transition-all duration-300";
                contentSafety.classList.remove('hidden');
                contentWriting.classList.add('hidden');
            } else {
                btnWriting.className = "px-6 py-2.5 text-xs tracking-widest uppercase bg-white text-luxuryBlack font-medium transition-all duration-300";
                btnSafety.className = "px-6 py-2.5 text-xs tracking-widest uppercase text-mutedGray hover:text-white transition-all duration-300";
                contentWriting.classList.remove('hidden');
                contentSafety.classList.add('hidden');
            }
            updatePricing();
        }

        // 3. Dynamic Calculation Matrix
        function updatePricing() {
            const slider = document.getElementById('volume-slider');
            const volume = parseInt(slider.value);
            
            document.getElementById('volume-level').textContent = `Scale Scale: Level ${volume} / 5`;
            
            let title = "";
            let multiplier = 0;
            let unitWord = "";
            
            if (currentTab === 'safety') {
                title = "Clinical Safety & Annotation Retainer";
                multiplier = 450;
                unitWord = "Hours / Month equivalent";
            } else {
                title = "Premium Medical Architecture Suite";
                multiplier = 350;
                unitWord = "Complex Deliverables / Scope";
            }
            
            const cost = volume * multiplier;
            const timeline = volume <= 2 ? "3-5 Business Days" : volume <= 4 ? "1-2 Weeks" : "Custom Distributed Sprint";
            
            document.getElementById('pricing-title').textContent = title;
            document.getElementById('pricing-cost').innerHTML = `$${cost.toLocaleString()}<span class="text-xs text-mutedGray font-sans tracking-normal font-light">/mo</span>`;
            document.getElementById('pricing-unit').textContent = `Includes roughly ${volume * 10} ${unitWord}`;
            document.getElementById('pricing-timeline').textContent = timeline;
        }

        // 4. Secure Transmission Copy Protocol
        document.getElementById('copy-btn').addEventListener('click', () => {
            navigator.clipboard.writeText("dr.tolu.ajidahun@gmail.com");
            const btn = document.getElementById('copy-btn');
            btn.textContent = "Copied";
            setTimeout(() => { btn.textContent = "Copy Loop"; }, 2000);
        });
    </script>
